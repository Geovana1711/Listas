#Programa para verificar se o triângulo é existente
lado1, lado2, lado3 = map(int, input("Digite o valor dos lados dos triângulos ").split())
# Verificação existência de um triângulo
if lado1 + lado2 > lado3 and lado2 + lado3 > lado1 and lado1 + lado3 > lado2:
    print("É um triângulo")
    if lado1 == lado2 == lado3:
        tipo_triangulo = "Equilátero"
    elif lado1 == lado2 or lado2 == lado3 or lado3 == lado2:
        tipo_triangulo = "Isósceles"
    else :
        tipo_triangulo ="Escaleno" 
        #resposta do tipo do triangulo 
    print(f"O triângulo é {tipo_triangulo}")
    
else:
    print(" Não é um triângulo")
